{
  "name": "cyber-grid-defense",
  "version": "1.0.0",
  "description": "赛博格点防线 (Cyber Grid Defense) - 经典策略塔防游戏",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --dir",
    "package": "electron-builder --win"
  },
  "keywords": [
    "towerdefense",
    "game",
    "cyberpunk"
  ],
  "author": "Antigravity",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.cybergrid.defense",
    "productName": "CyberGridDefense",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerSidebar": "build/installerSidebar.png",
      "installerHeader": "build/installerHeader.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "赛博格点防线"
    },
    "files": [
      "index.html",
      "styles.css",
      "main.js",
      "js/**/*"
    ]
  }
}
